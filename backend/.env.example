# Copy to .env and fill in your values

SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# Database (Railway auto-injects in production)
DATABASE_URL=sqlite:///db.sqlite3

# Redis (Railway auto-injects in production)
REDIS_URL=redis://127.0.0.1:6379/0

# Stripe — get from stripe.com/dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...   # $10/month consumer plan
STRIPE_LOOKUP_PRICE_ID=price_...    # $5 one-time lookup
STRIPE_DEALER_PRICE_ID=price_...    # $300/month dealer plan

# VINAudit — get from vinaudit.com
VINAUDIT_API_KEY=your-vinaudit-key-here

# Frontend URL (used for Stripe redirect URLs)
FRONTEND_URL=https://your-app.railway.app
